{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Live Downloader",
  "version": "1.0.1",
  "identifier": "app.livedownloader.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Live Downloader",
        "width": 1360,
        "height": 860,
        "minWidth": 980,
        "minHeight": 640,
        "visible": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://api.github.com; img-src 'self' asset: data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "shortDescription": "Record authorised live streams automatically",
    "longDescription": "A local Windows application that monitors approved stream URLs and records them when live.",
    "externalBin": [
      "binaries/yt-dlp",
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "resources": [
      "resources/third-party/ffmpeg/LICENSE",
      "resources/third-party/ffmpeg/README.txt"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows/hooks.nsh",
        "displayLanguageSelector": true,
        "languages": ["English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false
    }
  }
}
